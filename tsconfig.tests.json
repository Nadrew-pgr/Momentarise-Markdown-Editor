{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@momentarise/md-core": [
        "packages/md-core/src/index.ts"
      ],
      "@momentarise/md-format": [
        "packages/md-format/src/index.ts"
      ],
      "@momentarise/md-save": [
        "packages/md-save/src/index.ts"
      ],
      "@momentarise/md-policy": [
        "packages/md-policy/src/index.ts"
      ],
      "@momentarise/md-ai": [
        "packages/md-ai/src/index.ts"
      ],
      "@momentarise/md-editor": [
        "packages/md-editor/src/index.ts"
      ],
      "@momentarise/md-theme": [
        "packages/md-theme/src/index.ts"
      ],
      "@momentarise/md-preview-html": [
        "packages/md-preview-html/src/index.ts"
      ],
      "@momentarise/md-rich-prosemirror": [
        "packages/md-rich-prosemirror/src/index.ts"
      ],
      "@momentarise/md-source-codemirror": [
        "packages/md-source-codemirror/src/index.ts"
      ],
      "@momentarise/md-adapter-web": [
        "packages/md-adapter-web/src/index.ts"
      ],
      "@momentarise/md-cli": [
        "packages/md-cli/src/index.ts"
      ]
