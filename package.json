    "visual:mme-0014": "node scripts/visual-check-mme0014.mjs",
    "visual:mme-0015": "node scripts/visual-check-mme0015.mjs",
    "visual:mme-0017": "node scripts/visual-check-mme0017.mjs",
    "visual:mme-0018": "node scripts/visual-check-mme0018.mjs",
    "visual:mme-0019": "node scripts/visual-check-mme0019.mjs",
    "visual:mme-0021": "node scripts/visual-check-mme0021.mjs",
    "visual:mme-0022": "node scripts/visual-check-mme0022.mjs",
